# --- App ---
# Owner password — needed only to log in and see $ amounts, per-account
# details, and access write actions (rename, sync, etc.). Anyone visiting
# the URL without logging in gets the read-only guest view automatically.
APP_PASSWORD=changeme-please
SESSION_SECRET=generate-a-long-random-string

# --- Database ---
# Local: leave unset and we'll fall back to sqlite:///./jnvest.db
# Render: provided automatically by the Postgres add-on
DATABASE_URL=

# --- Alpaca (paper by default) ---
ALPACA_API_KEY=
ALPACA_API_SECRET=
ALPACA_BASE_URL=https://paper-api.alpaca.markets
ALPACA_DATA_URL=https://data.alpaca.markets

# --- Finnhub (news + econ calendar) ---
FINNHUB_API_KEY=

# --- FRED (optional, for macro) ---
FRED_API_KEY=

# --- SnapTrade (recommended for connecting Robinhood/Schwab/etc.) ---
# Free tier covers up to 5 brokerage connections — enough for personal use.
# Sign up at https://dashboard.snaptrade.com → copy clientId + consumerKey here.
SNAPTRADE_CLIENT_ID=
SNAPTRADE_CONSUMER_KEY=

# --- Plaid Investments (alternative; requires paid Production tier for real brokers) ---
# Sign up at https://dashboard.plaid.com — Sandbox keys are free (fake data only).
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox

# --- Frontend ---
# In dev, Vite proxies /api to the backend.
VITE_API_BASE=/api
