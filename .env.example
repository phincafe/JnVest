# --- App ---
APP_PASSWORD=changeme-please
SESSION_SECRET=generate-a-long-random-string

# --- Database ---
# Local: leave unset and we'll fall back to sqlite:///./jnvest.db
# Render: provided automatically by the Postgres add-on
DATABASE_URL=

# --- Alpaca (paper by default) ---
ALPACA_API_KEY=
ALPACA_API_SECRET=
ALPACA_BASE_URL=https://paper-api.alpaca.markets
ALPACA_DATA_URL=https://data.alpaca.markets

# --- Finnhub (news + econ calendar) ---
FINNHUB_API_KEY=

# --- FRED (optional, for macro) ---
FRED_API_KEY=

# --- Plaid Investments (optional, for connecting Robinhood/Schwab/Fidelity/etc.) ---
# Sign up at https://dashboard.plaid.com — Sandbox keys are free.
# PLAID_ENV: sandbox (free, fake data) or production (real institutions, paid).
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox

# --- Frontend ---
# In dev, Vite proxies /api to the backend.
VITE_API_BASE=/api
